# -----------------------------------------------------------------------------
# .env.example  --  template for nios_grid_capacity.py
#
# Copy this file to ".env" and fill in your values:
#     cp .env.example .env
#
# Rules:
#   * One KEY=value per line. Blank lines and lines starting with # are ignored.
#   * An optional leading "export " is allowed.
#   * Values may be quoted with ' or "  (recommended if the value contains a #).
#   * For UNQUOTED values, an inline " #" starts a comment.
#   * Command-line arguments ALWAYS override values set here.
#   * NEVER commit your real .env (the included .gitignore excludes it).
# -----------------------------------------------------------------------------

# --- Required (unless supplied on the command line) ---
NIOS_GRID_MANAGER=192.168.1.1
NIOS_USERNAME=admin
NIOS_OUTPUT=grid_capacity.csv

# --- Password ---
# If omitted here (and not passed with --password / env var), the script will
# securely prompt for it (input is hidden / obscured).
# Quote it if it contains a '#'.
#NIOS_PASSWORD="change-me"

# --- Optional (defaults shown) ---
#NIOS_WAPI_VERSION=v2.14
#NIOS_PAGE_SIZE=1000
#NIOS_TIMEOUT=60

# --- TLS ---
# Set NIOS_INSECURE=true for lab grids with self-signed certificates,
# OR point NIOS_CA_CERT at a PEM CA bundle (do not set both).
#NIOS_INSECURE=false
#NIOS_CA_CERT=/etc/ssl/corp-ca.pem
